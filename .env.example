# ============================================================
# CIP — Variables de entorno
# Copia este archivo a `.env` y ajusta los valores.
# ============================================================

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cip
POSTGRES_USER=cip
POSTGRES_PASSWORD=cip_dev_password

# --- MinIO (S3 local) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pubmed-raw
S3_REGION=us-east-1

# --- PubMed ---
# La API key es opcional pero recomendada (gratis, sube el rate limit
# de 3 req/s a 10 req/s). Crea una en:
# https://www.ncbi.nlm.nih.gov/account/  -> Settings -> API Key Management
PUBMED_API_KEY=
PUBMED_TOOL_NAME=clinical-intelligence-platform
PUBMED_EMAIL=tu-email@ejemplo.com

# --- API ---
LOG_LEVEL=INFO
API_PORT=8000
